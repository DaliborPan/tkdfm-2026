  "exports": {
    "./tailwind.config.js": "./tailwind.config.js",
    "./scripts": {
      "import": "./scripts/index.ts"
    }
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/typography": "^0.5.10",
    "tailwindcss": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "@types/color": "^3.0.6",
    "@types/inquirer": "^9.0.7",
    "color": "^4.2.3",
    "iqf-web-typescript": "workspace:*",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "inquirer": "^9.2.12"
  }
}
