{
  "name": "iqf-web-tailwind",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "create-palette": "node --no-warnings=ExperimentalWarning --loader ts-node/esm ./scripts/create-palette.ts"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./scripts/index.ts"
      ]
